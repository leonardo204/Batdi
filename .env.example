# ─────────────────────────────────────────────────────────────
# 밧디 (batdi) 환경 변수 예시 — 값은 비워둠. 복사 후 .env 로 채운다.
# cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Database (PostgreSQL 16 + PgBouncer) ─────────────────────
# 외부 포트: PostgreSQL 54329, PgBouncer 54330 (둘 다 private/높은 포트)
POSTGRES_DB=batdi
POSTGRES_USER=
POSTGRES_PASSWORD=
# 앱 런타임: PgBouncer(54330, transaction pooling) 경유.
#   ?pgbouncer=true → Prisma 가 prepared statement 를 비활성(transaction 모드 호환)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:54330/batdi?pgbouncer=true
# Prisma 마이그레이션/introspection: PostgreSQL 직결(54329). pooling 우회 필수.
DIRECT_URL=postgresql://USER:PASSWORD@localhost:54329/batdi

# ── LLM (Gemini) ────────────────────────────────────────────
GEMINI_API_KEY=
# LangGraph 노드(apps/agent)가 직접 사용하는 키. 비워두면 캔드(스켈레톤) 응답.
# (langchain google-genai 표준 키 이름)
GOOGLE_API_KEY=

# ── LangGraph Agent (ADR-016: LangGraph-over-HTTP) ──────────
# api(CopilotRuntime, LangGraphAgent)가 호출하는 langgraphjs dev 서버 주소
LANGGRAPH_URL=http://localhost:8123
# CopilotKit 익명 텔레메트리 비활성(런타임 v1.60 텔레메트리 크래시 회피).
# api 코드에서 기본 true 로 강제하지만, 명시적으로 둔다.
COPILOTKIT_TELEMETRY_DISABLED=true

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=

# ── Langfuse (셀프호스팅 관측) ──────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3010
# Langfuse 컨테이너 자체 설정 (docker-compose.yml 참조)
LANGFUSE_DB_USER=
LANGFUSE_DB_PASSWORD=
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=

# ── Web Push (P4-W11 — VAPID, 로컬) ─────────────────────────
# 로컬 키 생성: `npx web-push generate-vapid-keys` 실행 후 아래 두 값에 붙여넣는다.
#   (api 의 web-push 가 setVapidDetails 로 사용. 미설정 시 푸시는 graceful 비활성 — throw 안 함.)
# VAPID_SUBJECT 는 mailto: 또는 https URL(권장 mailto). 공개키는 web 구독 시
#   GET /api/push/vapid-public-key 로 전달된다(별도 NEXT_PUBLIC 노출 불필요).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@batdi.kr
# 경기 시작 30분 전 푸시 cron 스윕 활성 게이트(기본 비활성 — CI/테스트 푸시 방지).
PUSH_ENABLED=false

# ── API / Web ───────────────────────────────────────────────
API_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001
# CORS 허용 오리진 (web)
WEB_ORIGIN=http://localhost:3000
