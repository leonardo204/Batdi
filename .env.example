# ─────────────────────────────────────────────────────────────
# 밧디 (batdi) 환경 변수 예시 — 값은 비워둠. 복사 후 .env 로 채운다.
# cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Database (PostgreSQL 16, Docker 포트 54329) ──────────────
POSTGRES_DB=batdi
POSTGRES_USER=
POSTGRES_PASSWORD=
# 앱에서 사용하는 커넥션 문자열 (P1 PgBouncer 도입 전까지 직결)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:54329/batdi

# ── LLM (Gemini) ────────────────────────────────────────────
GEMINI_API_KEY=

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=

# ── Langfuse (셀프호스팅 관측) ──────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3010
# Langfuse 컨테이너 자체 설정 (docker-compose.yml 참조)
LANGFUSE_DB_USER=
LANGFUSE_DB_PASSWORD=
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=

# ── API / Web ───────────────────────────────────────────────
API_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001
# CORS 허용 오리진 (web)
WEB_ORIGIN=http://localhost:3000
